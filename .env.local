# ══════════════════════════════════════════════════════════════════════════════
# Jira Ticket Resolver Agent v6.0 — Configuration Template
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════════════════════════════

# ── Jira Connection ────────────────────────────────────────────────────────────
JIRA_URL=https://yourcompany.atlassian.net

# Authentication (choose one):
# Cloud: email + API token
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-api-token-here
# Server/DC: personal access token
# JIRA_PAT=your-pat-here

# ── Ticket Filtering ──────────────────────────────────────────────────────────
# Simple: project key (fetches all open tickets)
JIRA_PROJECT=ENG
# Advanced: custom JQL (overrides JIRA_PROJECT)
# JIRA_JQL=project = ENG AND sprint in openSprints()

# ── Jira Write-Back ───────────────────────────────────────────────────────────
# true = update ticket status + add comment after patching
JIRA_WRITE_BACK=false

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: openrouter, openai, anthropic, google, qwen
PROVIDER=openrouter
API_KEY=your-llm-api-key
MODEL=google/gemini-2.5-flash
# Custom endpoint (optional):
# API_ENDPOINT=https://your-private-llm.com/v1/chat/completions

# ── Codebase ──────────────────────────────────────────────────────────────────
CODEBASE_PATH=C:\path\to\your\project
